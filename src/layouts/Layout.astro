---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'DUXER | Equipos Industriales de Lavandería',
  description = 'Distribución de lavadoras de barrera sanitaria y equipos para hoteles, clubes deportivos, maquinadoras y constructoras en Argentina. Garantía de 2 años, refacciones y soporte especializado.',
  ogImage = '/og-image.jpg',
} = Astro.props;

const siteUrl = 'https://duxer.com.ar';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={siteUrl} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="DUXER Equipo Industrial" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- GEO -->
    <meta name="geo.region" content="AR" />
    <meta name="geo.placename" content="Buenos Aires" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: Organization -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "DUXER Equipo Industrial",
        "url": "https://duxer.com.ar",
        "logo": "https://duxer.com.ar/favicon.svg",
        "description": "Distribución de equipos industriales de lavandería con garantía de calidad y atención. Lavadoras de barrera sanitaria para hoteles, clubes deportivos, maquinadoras y constructoras.",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Buenos Aires",
          "addressCountry": "AR"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+54-11-7867-1075",
          "contactType": "customer service",
          "availableLanguage": "Spanish",
          "hoursAvailable": {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "09:00",
            "closes": "18:00"
          }
        },
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Equipos de Lavandería Industrial",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Lavado Industrial" } },
            { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Secado Inteligente" } },
            { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Acabado Profesional" } },
            { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Planchado Industrial" } }
          ]
        }
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
