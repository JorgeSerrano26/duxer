<section class="bg-[#060606] py-24 px-6 border-y border-white/[0.05]" aria-label="Garantía de 2 años">
  <div class="max-w-[600px] mx-auto flex flex-col items-center text-center gap-8">
    <div class="w-[260px] h-[260px] flex items-center justify-center reveal">
      <img
        src="/garantia.png"
