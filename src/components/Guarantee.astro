---

---

<section
  class="relative py-24 px-6 overflow-hidden"
  aria-label="Garantía de 2 años"
>
  <!-- Background image -->
  <div class="absolute inset-0 w-full h-full">
    <img
      src="/duxer-bg-03.webp"
      alt=""
      width="1400"
      height="600"
      loading="lazy"
      aria-hidden="true"
      class="w-full h-full object-cover pointer-events-none"
    />
    <!-- Top fade -->
    <div
      class="absolute inset-x-0 top-0 h-[25%] pointer-events-none"
      style="background: linear-gradient(to bottom, #060606 0%, transparent 100%);"
    >
    </div>
    <!-- Bottom fade -->
    <div
      class="absolute inset-x-0 bottom-0 h-[25%] pointer-events-none"
      style="background: linear-gradient(to top, #060606 0%, transparent 100%);"
    >
    </div>
    <!-- Left fade -->
    <div
      class="absolute inset-y-0 left-0 w-[20%] pointer-events-none"
      style="background: linear-gradient(to right, #060606 0%, transparent 100%);"
    >
    </div>
    <!-- Right fade -->
    <div
      class="absolute inset-y-0 right-0 w-[20%] pointer-events-none"
      style="background: linear-gradient(to left, #060606 0%, transparent 100%);"
    >
    </div>
    <!-- Dark overlay for contrast -->
    <div class="absolute inset-0 bg-black/55 pointer-events-none"></div>
  </div>

  <!-- Map background -->
  <div class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true">
    <img
      src="/mapa.webp"
      alt=""
      width="1400"
      height="600"
      loading="lazy"
      class="w-full h-full object-cover opacity-10"
    />
  </div>

  <div
    class="relative z-10 duxer-container flex flex-col items-center text-center gap-8"
  >
    <div class="flex items-center justify-center reveal">
      <img
        src="/garantia.webp"
        alt="Sello oficial de Garantía 2 Años DUXER"
        width="450"
        height="384"
        class="object-contain mix-blend-screen"
        loading="lazy"
      />
    </div>

    <div class="flex flex-col gap-3 reveal">
      <p
        class="font-heading font-bold text-[clamp(1.8rem,4vw,2.8rem)] tracking-[0.04em] text-white uppercase leading-[1.4] m-0"
      >
        Todos nuestros equipos cuentan con garantía de 2 años.
      </p>
      <p
        class="font-body text-[clamp(0.95rem,1.5vw,1.15rem)] text-white leading-[1.75] max-w-105 mx-auto m-0"
      >
        Respaldamos la calidad, durabilidad y rendimiento de cada solución que
        ofrecemos.
      </p>
    </div>
  </div>
</section>
