<section class="guarantee" aria-label="Garantía de 2 años">
  <div class="guarantee-wrap">
    <div class="badge-container reveal">
      <img
        src="/garantia.png"
        alt="Sello oficial de Garantía 2 Años DUXER"
        width="300"
        height="300"
        class="badge-img"
        loading="lazy"
      />
    </div>

    <div class="guarantee-text reveal">
      <p class="guarantee-title">
        Todos nuestros equipos cuentan con garantía de 2 años.
      </p>
      <p class="guarantee-body">
        Respaldamos la calidad, durabilidad y rendimiento de cada solución que ofrecemos.
      </p>
    </div>
  </div>
</section>

<style>
  .guarantee {
    background-color: #060606;
    padding: 6rem 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .guarantee-wrap {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2rem;
  }

  .badge-container {
    width: 260px;
    height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .badge-img {
    width: 260px;
    height: 260px;
    object-fit: contain;
    mix-blend-mode: screen;
  }

  .guarantee-text {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .guarantee-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    color: white;
    text-transform: uppercase;
    line-height: 1.4;
    margin: 0;
  }

  .guarantee-body {
    font-family: 'Barlow', sans-serif;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.75;
    max-width: 420px;
    margin: 0 auto;
  }
</style>
