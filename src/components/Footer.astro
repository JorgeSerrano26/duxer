---
const year = new Date().getFullYear();
---

<footer class="bg-[#060606] border-t border-white/[0.06] pt-14 px-6 pb-0" aria-label="Pie de página DUXER">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-10 pb-12 border-b border-white/[0.06]">

    <!-- Col 1: Description -->
    <div class="flex flex-col justify-center">
      <p class="font-body text-[0.8rem] leading-[1.8] text-white/40 max-w-[280px] m-0 p-0">
        Distribución de equipo industrial para lavanderías.
      </p>
    </div>

    <!-- Col 2: Contact info (centered) -->
    <div class="flex flex-col items-center text-center gap-[0.3rem]">
      <a href="tel:+529841885279" class="font-body text-[0.82rem] text-white/60 no-underline hover:text-white/90 transition-colors duration-200">+52 984 188 5279</a>
      <a href="https://wa.me/529841885279" class="font-body text-[0.82rem] text-white/60 no-underline hover:text-white/90 transition-colors duration-200">WhatsApp: +52 984 188 5279</a>
      <a href="mailto:info@duxer.com.mx" class="font-body text-[0.82rem] text-white/60 no-underline hover:text-white/90 transition-colors duration-200">info@duxer.com.mx</a>
      <p class="font-body text-[0.82rem] text-white/60 m-0 p-0">México. Alcance nacional.</p>
      <div class="mt-2">
        <p class="font-heading font-bold text-[0.82rem] text-white/80 m-0 p-0">Horario de atención</p>
        <p class="font-body text-[0.82rem] text-white/60 m-0 p-0">Lunes a sábado, 9:00 a.m. a 6:00 p.m.</p>
      </div>
    </div>

    <!-- Col 3: Logo + Instagram -->
    <div class="flex flex-col items-end gap-4">
      <a href="/" aria-label="DUXER" class="no-underline">
        <img src="/logo.webp" alt="DUXER Equipo Industrial" width="160" height="42" />
      </a>
      <a
        href="https://instagram.com/duxerequipoindustrial"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 no-underline group"
        aria-label="Instagram de DUXER"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-white/50 group-hover:text-white/90 transition-colors duration-200">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        <span class="font-heading font-bold text-[0.72rem] tracking-[0.12em] uppercase text-white/50 group-hover:text-white/90 transition-colors duration-200">@DUXEREQUIPOINDUSTRIAL</span>
      </a>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="max-w-[1200px] mx-auto py-5 grid grid-cols-3 items-center max-md:flex max-md:flex-col max-md:gap-3 max-md:items-start">
    <a href="/politica-de-privacidad" class="font-body text-[0.7rem] text-white/[0.22] no-underline hover:text-white/60 transition-colors duration-200">Política de Privacidad</a>
    <p class="font-body text-[0.7rem] text-white/20 m-0 p-0 text-center max-md:text-left">
      © {year} DUXER Equipo Industrial<br />Todos los derechos reservados
    </p>
    <a href="/declaracion-de-accesibilidad" class="font-body text-[0.7rem] text-white/[0.22] no-underline hover:text-white/60 transition-colors duration-200 text-right max-md:text-left">Declaracion de accesibilidad</a>
  </div>
</footer>
