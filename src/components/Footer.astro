---
const year = new Date().getFullYear();

const contacts = [
  { label: "Tel.", value: "(11) 7867-1075", href: "tel:+541178671075" },
  {
    label: "WhatsApp",
    value: "(11) 1254-0275",
    href: "https://wa.me/5491112540275",
  },
  {
    label: "Email",
    value: "info@duxer.com.ar",
    href: "mailto:info@duxer.com.ar",
  },
];

const navLinks = [
  { label: "Nosotros", href: "#nosotros" },
  { label: "Soluciones", href: "#soluciones" },
  { label: "Productos", href: "#productos" },
  { label: "Contacto", href: "#contacto" },
];
---

<footer class="bg-[#060606] border-t border-white/[0.06] pt-16 px-6 pb-0" aria-label="Pie de página DUXER">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-[1.6fr_1fr_1fr] gap-12 pb-14 border-b border-white/[0.06]">
    <!-- Col 1: Brand -->
    <div class="flex flex-col">
      <a href="/" class="flex items-center gap-2.5 no-underline mb-5" aria-label="DUXER">
        <img src="/logo.webp" alt="DUXER" width="250" height="66" />
      </a>
      <p class="font-body text-[0.8rem] leading-[1.75] text-white/[0.33] max-w-[280px] m-0 p-0">
        Distribución de equipos industriales de lavandería para hoteles, clubes
        deportivos, maquinadoras y constructoras. Garantía, refacciones y
        soporte especializado.
      </p>
    </div>

    <!-- Col 2: Nav -->
    <div class="flex flex-col">
      <p class="font-heading font-bold text-[0.65rem] tracking-[0.28em] uppercase text-white/[0.28] m-0 mb-5 p-0">Navegación</p>
      <ul class="list-none m-0 p-0 flex flex-col gap-2.5">
        {
          navLinks.map((l) => (
            <li class="m-0 p-0">
              <a href={l.href} class="font-body text-[0.82rem] text-white/[0.42] no-underline transition-colors duration-200 inline-block hover:text-white/85">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Col 3: Contact -->
    <div class="flex flex-col">
      <p class="font-heading font-bold text-[0.65rem] tracking-[0.28em] uppercase text-white/[0.28] m-0 mb-5 p-0">Contacto</p>
      <ul class="list-none m-0 p-0 flex flex-col gap-2.5 mb-5">
        {
          contacts.map((c) => (
            <li class="m-0 p-0 flex gap-2.5 items-start">
              <span class="font-heading font-semibold text-[0.62rem] tracking-[0.1em] uppercase text-gold/60 min-w-[60px] shrink-0 pt-px inline-block">
                {c.label}
              </span>
              <a href={c.href} class="font-body text-[0.8rem] text-white/45 no-underline transition-colors duration-200 hover:text-white/85">
                {c.value}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="border-t border-white/[0.06] pt-4">
        <p class="font-heading text-[0.62rem] tracking-[0.15em] uppercase text-white/[0.22] m-0 mb-1 p-0">Horario de atención</p>
        <p class="font-body text-[0.78rem] text-white/[0.38] m-0 p-0">Lunes a Viernes · 9:00 am – 6:00 pm</p>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="max-w-[1200px] mx-auto py-5 flex items-center justify-between flex-wrap gap-3 max-md:flex-col max-md:items-start">
    <p class="font-body text-[0.7rem] text-white/20 m-0 p-0">
      © {year} DUXER Equipo Industrial. Todos los derechos reservados.
    </p>
    <div class="flex gap-6">
      <a href="#" class="font-body text-[0.7rem] text-white/[0.22] no-underline transition-colors duration-200 hover:text-white/60">Política de Privacidad</a>
      <a href="#" class="font-body text-[0.7rem] text-white/[0.22] no-underline transition-colors duration-200 hover:text-white/60">Declaración de accesibilidad</a>
    </div>
  </div>
</footer>
