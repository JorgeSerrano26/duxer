---
---

<section id="inicio" class="hero" aria-label="Sección principal">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="hero-bottom-fade" aria-hidden="true"></div>

  <div class="hero-content">
    <p class="hero-eyebrow">
      <span class="eyebrow-line"></span>
      Equipo Industrial · Buenos Aires, AR
    </p>

    <h1 class="hero-heading">
      Equipos industriales de lavandería, con garantía de calidad y atención.
    </h1>

    <p class="hero-subtitle">
      Distribución de lavadoras de barrera sanitaria y equipos para hoteles,
      clubes deportivos, maquinadoras, constructoras. Contamos con
      refacciones y soporte especializado.
    </p>

    <div class="hero-actions">
      <a href="#contacto" class="hero-btn-primary">Solicitar cotización</a>
      <a href="#soluciones" class="hero-btn-outline">Ver soluciones</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    background-color: #060606;
    display: flex;
    align-items: center;
  }

  /* Background image — hero.jpg, dark metallic industrial */
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/hero.jpg');
    background-size: cover;
    background-position: center center;
    opacity: 0.6;
  }

  /* Left-heavy gradient: fully opaque on left, transparent on right */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(6, 6, 6, 1)    0%,
      rgba(6, 6, 6, 0.92) 40%,
      rgba(6, 6, 6, 0.45) 70%,
      rgba(6, 6, 6, 0.1)  100%
    );
  }

  /* Bottom fade into the next dark section */
  .hero-bottom-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 200px;
    background: linear-gradient(to top, #060606, transparent);
    pointer-events: none;
  }

  /* Content — positioned over the overlays */
  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 9rem clamp(1.5rem, 5vw, 4rem) 5rem;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(200, 168, 107, 0.9);
    margin-bottom: 1.5rem;
  }

  .eyebrow-line {
    display: inline-block;
    width: 30px;
    height: 1px;
    background: rgba(200, 168, 107, 0.55);
    flex-shrink: 0;
  }

  .hero-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2.6rem, 5.5vw, 5rem);
    line-height: 1.02;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    max-width: 600px;
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-family: 'Barlow', sans-serif;
    font-size: clamp(0.85rem, 1.3vw, 0.98rem);
    line-height: 1.78;
    color: rgba(255, 255, 255, 0.52);
    max-width: 460px;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .hero-btn-primary {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: white;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.38);
    padding: 0.75rem 1.75rem;
    transition: background 0.2s, border-color 0.2s;
  }

  .hero-btn-primary:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.7);
  }

  .hero-btn-outline {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.18);
    padding: 0.75rem 1.75rem;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .hero-btn-outline:hover {
    color: white;
    border-color: rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.06);
  }

  @media (max-width: 768px) {
    .hero-overlay {
      background: rgba(6, 6, 6, 0.85);
    }
    .hero-heading {
      max-width: 100%;
    }
    .hero-subtitle {
      max-width: 100%;
    }
  }
</style>
