---

---

<section
  id="inicio"
  class="relative h-dvh bg-[#060606] flex items-center overflow-hidden"
  aria-label="Sección principal"
>
  <div
    class="absolute inset-0 bg-[url('/hero.jpg')] bg-cover bg-center opacity-60"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute inset-0 bg-[linear-gradient(100deg,rgba(6,6,6,1)_0%,rgba(6,6,6,0.92)_40%,rgba(6,6,6,0.45)_70%,rgba(6,6,6,0.1)_100%)] max-md:bg-[rgba(6,6,6,0.85)]"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 right-0 h-50 bg-[linear-gradient(to_top,#060606,transparent)] pointer-events-none z-[1]"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-[3] w-full duxer-container pt-36 pb-20">
    <!-- Collage image — absolute bottom right on desktop >=1200px -->
    <div
      class="absolute right-6 bottom-20 w-[55%] pointer-events-none hidden min-[1200px]:block"
      aria-hidden="true"
    >
      <img
        src="/colage.png"
        alt=""
        class="w-full h-auto object-contain"
        loading="eager"
      />
    </div>

    <div class="relative max-w-[70%] max-[1199px]:max-w-full">
      <p
        class="flex items-center gap-3 font-heading font-semibold text-[0.68rem] tracking-[0.22em] uppercase text-gold/90 mb-6"
      >
        <span class="inline-block w-[30px] h-px bg-gold/55 shrink-0"></span>
        Equipo Industrial · Playa del Carmen, MX
      </p>

      <h1
        class="font-heading font-black text-[clamp(2.8rem,6vw,5.2rem)] leading-[1.02] text-white uppercase tracking-[0.01em] mb-6"
      >
        Equipos industriales de lavandería, con garantía de calidad y atención.
      </h1>

      <p
        class="font-body text-[clamp(0.85rem,1.3vw,0.98rem)] leading-[1.78] text-white/[0.52] max-w-[460px] mb-10 max-[1199px]:max-w-full"
      >
        Distribución de equipo industrial para lavanderías, con servicio 360,
        refacción, soporte especializado y asesoría profesional.
      </p>

      <div class="flex gap-3.5 flex-wrap items-center max-md:flex-col">
        <a
          href="#contacto"
          class="group relative font-heading font-bold text-[0.95rem] tracking-[0.12em] uppercase text-[#060606] no-underline bg-gold px-9 py-4 shadow-[0_0_24px_rgba(191,155,48,0.45)] transition-all duration-300 hover:bg-gold/90 hover:shadow-[0_0_36px_rgba(191,155,48,0.65)] hover:scale-[1.03] active:scale-[0.98] max-md:w-full max-md:text-center"
        >
          Solicitar cotización
          <span
            class="absolute inset-0 rounded-[inherit] border-2 border-gold/60 animate-pulse pointer-events-none"
          ></span>
        </a>
        <a
          href="#soluciones"
          class="font-heading font-bold text-[0.95rem] tracking-[0.12em] uppercase text-white/65 no-underline border border-white/[0.18] px-9 py-4 transition-[color,border-color,background] duration-200 hover:text-white hover:border-white/45 hover:bg-white/[0.06] max-md:w-full max-md:text-center"
        >
          Ver soluciones
        </a>
      </div>
    </div>

    <!-- Collage image below actions for <1200px -->
    <div class="block min-[1200px]:hidden mt-8">
      <img
        src="/colage.png"
        alt="Collage de equipos industriales de lavandería"
        class="w-full max-w-250 mx-auto h-auto object-contain"
        loading="eager"
      />
    </div>
  </div>
</section>
