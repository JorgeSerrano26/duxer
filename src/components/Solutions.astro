---
const services = [
  {
    title: 'Asesoría y Proyectos',
    body: 'Diseñamos la disposición de la lavandería para maximizar flujos de trabajo eficientes y óptimos. Te acompañamos desde el análisis inicial de necesidades hasta la implementación completa.',
    detail: 'Te acompañamos desde la planeación hasta la implementación.',
    image: '/lavandery.png',
    alt: 'Equipo de asesoría DUXER planificando la disposición de una lavandería industrial',
  },
  {
    title: 'Venta y Soporte',
    body: 'Venta de lavadoras, secadoras y equipos industriales de alta eficiencia diseñados para trabajo continuo, con soporte postventa para asegurar el rendimiento óptimo de tu operación.',
    detail: 'Soporte postventa para asegurar el rendimiento óptimo de tu operación.',
    image: '/lavado_industrial.png',
    alt: 'Lavadora industrial DUXER — venta y soporte técnico especializado',
  },
];
---

<section id="soluciones" class="solutions" aria-label="Soluciones integrales">
  <div class="solutions-inner">
    <header class="solutions-header reveal">
      <h2 class="solutions-heading">
        Soluciones integrales<br />para tu operación
      </h2>
      <p class="solutions-sub">
        Servicios especializados que respaldan el desempeño y la continuidad de tu operación.
      </p>
    </header>

    <div class="solutions-grid">
      {services.map((s) => (
        <article class="service-card reveal">
          <div class="card-img-wrap">
            <img
              src={s.image}
              alt={s.alt}
              width="580"
              height="300"
              loading="lazy"
              class="card-img"
            />
          </div>
          <div class="card-body">
            <h3 class="card-title">{s.title}</h3>
            <p class="card-text">{s.body}</p>
            <p class="card-detail">{s.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .solutions {
    background: #f0efea;
    padding: 5.5rem 1.5rem;
  }

  .solutions-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .solutions-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .solutions-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.0;
    color: #0a0a0a;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .solutions-sub {
    font-family: 'Barlow', sans-serif;
    font-size: 0.9rem;
    color: rgba(0, 0, 0, 0.45);
    line-height: 1.6;
    max-width: 420px;
    margin: 0 auto;
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .service-card {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    overflow: hidden;
    transition: box-shadow 0.3s, transform 0.3s;
  }

  .service-card:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
    transform: translateY(-3px);
  }

  .card-img-wrap {
    overflow: hidden;
    background: #e8e7e2;
  }

  .card-img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .service-card:hover .card-img {
    transform: scale(1.04);
  }

  .card-body {
    padding: 1.75rem;
  }

  .card-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1.35rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #0a0a0a;
    margin-bottom: 0.75rem;
  }

  .card-text {
    font-family: 'Barlow', sans-serif;
    font-size: 0.85rem;
    line-height: 1.75;
    color: rgba(0, 0, 0, 0.5);
    margin-bottom: 0.75rem;
  }

  .card-detail {
    font-family: 'Barlow', sans-serif;
    font-size: 0.78rem;
    font-style: italic;
    color: rgba(0, 0, 0, 0.35);
  }

  @media (max-width: 640px) {
    .solutions-grid { grid-template-columns: 1fr; }
  }
</style>
