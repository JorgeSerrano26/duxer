---
const services = [
  {
    title: 'Asesoría y Proyectos',
    body: 'Diseñamos la disposición de tu lavandería para maximizar el flujo de trabajo y optimizar el espacio, ya sea para un hotel boutique, hospital o planta industrial.',
    detail: 'Te acompañamos desde la planeación hasta la implementación.',
    image: '/solution-01.webp',
    alt: 'Equipo de asesoría DUXER planificando la disposición de una lavandería industrial',
  },
  {
    title: 'Venta y Soporte',
    body: 'Venta de lavadoras, secadoras y equipos industriales. Equipos de alta eficiencia diseñados para trabajo continuo, con respaldo técnico especializado y garantía directa.',
    detail: 'Soporte postventa para asegurar el rendimiento óptimo de tu operación.',
    image: '/solution-02.webp',
    alt: 'Asesor DUXER brindando soporte técnico especializado a cliente',
  },
];
---

<section id="soluciones" class="bg-paper py-[5.5rem] px-6" aria-label="Soluciones integrales">
  <div class="duxer-container">
    <header class="text-center mb-14 reveal">
      <h2 class="font-heading font-black text-[clamp(2rem,5vw,3.25rem)] leading-none text-[#0a0a0a] uppercase tracking-[0.05em] mb-4">
        Soluciones integrales<br />para tu operación
      </h2>
      <p class="font-body text-[0.9rem] text-black/45 leading-[1.6] max-w-[420px] mx-auto">
        Servicios especializados que respaldan el desempeño y la continuidad de tu operación.
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-[900px] mx-auto">
      {services.map((s) => (
        <article class="rounded-3xl overflow-hidden flex flex-col reveal" style="min-height: 520px;">
          <!-- Top 50%: image -->
          <div class="flex-1 overflow-hidden">
            <img
              src={s.image}
              alt={s.alt}
              width="580"
              height="320"
              loading="lazy"
              class="w-full h-full object-cover block"
            />
          </div>

          <!-- Bottom 50%: dark content -->
          <div class="flex-1 bg-[#0f0f0f] px-8 py-8 flex flex-col justify-center">
            <h3 class="font-heading font-black text-[1.6rem] tracking-[0.03em] uppercase text-white mb-4 leading-[1.1]">
              {s.title}
            </h3>
            <p class="font-body text-[1rem] leading-[1.75] text-white/50 mb-3">
              {s.body}
            </p>
            <p class="font-body text-[0.9rem] italic text-white/30">
              {s.detail}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
