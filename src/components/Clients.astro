---
---

<section class="bg-[#0d0d0d] border-y border-white/[0.05] py-10 px-6 text-center" aria-label="Nuestros clientes">
  <div class="max-w-[900px] mx-auto">
    <p class="font-heading font-bold text-[0.65rem] tracking-[0.3em] uppercase text-white/35 mb-2.5">Nuestros clientes</p>

    <p class="font-body text-[0.78rem] text-white/30 tracking-[0.04em] mb-7">
      Hoteles &nbsp;·&nbsp; Clubes deportivos &nbsp;·&nbsp; Maquinadoras &nbsp;·&nbsp; Constructoras &nbsp;·&nbsp; Entre otros
    </p>

    <div class="flex items-center justify-center gap-10 flex-wrap" aria-label="Logos de clientes">
      {[1, 2, 3].map((i) => (
        <div class="opacity-45 transition-opacity duration-[250ms] hover:opacity-80" aria-label={`Hard Rock Cafe`}>
          <svg viewBox="0 0 120 48" width="120" height="48" aria-hidden="true">
            <rect x="0" y="0" width="120" height="48" fill="none"/>
            <text x="60" y="20" text-anchor="middle"
              font-family="'Barlow Condensed', sans-serif"
              font-weight="900"
              font-size="18"
              fill="white"
              letter-spacing="1">HARD ROCK</text>
            <line x1="10" y1="26" x2="110" y2="26" stroke="rgba(255,255,255,0.3)" stroke-width="0.5"/>
            <text x="60" y="40" text-anchor="middle"
              font-family="'Barlow Condensed', sans-serif"
              font-weight="400"
              font-size="9"
              fill="rgba(255,255,255,0.5)"
              letter-spacing="4">C A F E</text>
          </svg>
        </div>
      ))}
    </div>
  </div>
</section>
