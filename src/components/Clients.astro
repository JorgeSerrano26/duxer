---

<section class="bg-[#0d0d0d] border-y border-white/[0.05] py-14 px-6 text-center" aria-label="Nuestros clientes">
  <div class="max-w-[1200px] mx-auto">
    <p class="font-heading font-bold text-[1rem] tracking-[0.3em] uppercase text-white/60 mb-3">Nuestros clientes</p>

    <p class="font-body text-[0.9rem] text-white/40 tracking-[0.04em] mb-10">
      Hoteles &nbsp;·&nbsp; Clubes deportivos &nbsp;·&nbsp; Maquinadoras &nbsp;·&nbsp; Constructoras &nbsp;·&nbsp; Entre otros
    </p>

    <div class="flex items-center justify-center gap-14 flex-wrap" aria-label="Logos de clientes">
      <div class="opacity-50 transition-opacity duration-[250ms] hover:opacity-90">
        <img
          src="/clientes/hardrock.png"
          alt="Hard Rock Cafe"
          width="180"
          height="72"
          loading="lazy"
          class="h-16 w-auto object-contain brightness-0 invert"
        />
      </div>
      <div class="opacity-50 transition-opacity duration-[250ms] hover:opacity-90">
        <img
          src="/clientes/seadust.png"
          alt="Seadust Cancún Family Resort"
          width="180"
          height="72"
          loading="lazy"
          class="h-16 w-auto object-contain brightness-0 invert"
        />
      </div>
      <div class="opacity-50 transition-opacity duration-[250ms] hover:opacity-90">
        <img
          src="/clientes/ava.webp"
          alt="Hotel Ava Cancún"
          width="180"
          height="72"
          loading="lazy"
          class="h-16 w-auto object-contain brightness-0 invert"
        />
      </div>
    </div>
  </div>
</section>
