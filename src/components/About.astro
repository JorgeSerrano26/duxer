---
---

<section id="nosotros" class="relative bg-ink overflow-hidden min-h-[520px] flex items-center" aria-label="Sobre DUXER">
  <!-- Full-width background image -->
  <img
    src="/lavandery.png"
    alt="Equipos de lavandería industrial DUXER — fila de lavadoras de barrera sanitaria"
    width="1400"
    height="550"
    loading="lazy"
    class="absolute inset-0 w-full h-full object-cover"
  />

  <!-- Gradient overlay: black on left fading to transparent on right -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(to right, #060606 0%, #060606 35%, rgba(6,6,6,0.75) 55%, rgba(6,6,6,0.1) 80%, transparent 100%);"
    aria-hidden="true"
  ></div>

  <!-- Text content -->
  <div class="relative z-10 w-full duxer-container py-20 max-md:py-12">
    <div class="flex flex-col justify-center reveal max-w-[520px]">
      <h2 class="font-heading font-black text-[clamp(2.75rem,5vw,4.5rem)] leading-[0.95] text-white uppercase tracking-[0.03em] mb-7">
        Tu garantía<br />
        en atención<br />
        y calidad
      </h2>

      <div class="w-9 h-0.5 bg-gold/60 mb-7"></div>

      <p class="font-body text-[0.9rem] leading-[1.8] text-white/50 mb-4 max-w-[380px]">
        Como empresa orgullosamente Mexicana, en Duxer creamos una propuesta
        personalizada para las necesidades de tu empresa, maximizando el
        desempeño y la continuidad de tu operación.
      </p>
    </div>
  </div>
</section>
