---
const products = [
  {
    name: "Lavado Industrial",
    subtitle: "Lavado industrial a tu alcance",
    desc: "Lavadoras industriales disponibles en capacidades de 15 kg, 30 kg, 35 kg, 50 kg y hasta 100 kg.",
    image: "/lavado_industrial.png",
    alt: "Lavadora industrial de barrera sanitaria DUXER, acero inoxidable",
  },
  {
    name: "Secado Inteligente",
    subtitle: "Soluciones de secado inteligente",
    desc: "Secadoras industriales de 15 kg a 100 kg diseñadas para manejar grandes volúmenes con precisión y velocidad.",
    image: "/secado_inteligente.png",
    alt: "Secadora industrial inteligente DUXER de alta eficiencia",
  },
  {
    name: "Acabado Profesional",
    subtitle: "Ofrecemos equipos de acuerdo a las necesidades de su producción",
    desc: "Equipos industriales de distintos tamaños y sistemas de calentamiento (vapor, eléctrico o gas).",
    image: "/acabado_profesional.png",
    alt: "Equipo de acabado profesional DUXER para lavandería industrial",
  },
  {
    name: "Planchado",
    subtitle: "Acabados profesionales de alto rendimiento",
    desc: "Calandrias y planchas industriales para sábanas, manteles y uniformes con acabado perfecto.",
    image: "/planchado.png",
    alt: "Calandria industrial DUXER para planchado profesional de lencería",
  },
];
---

<section
  id="productos"
  class="py-22 px-6 relative overflow-hidden"
  aria-label="Líneas de producto"
>
  <div class="absolute w-full h-full left-0 top-0">
    <img
      src="/duxer-bg-01.png"
      alt="Fondo decorativo de textura industrial para sección de productos DUXER"
      width="1400"
      height="550"
      loading="lazy"
      class="inset-0 w-full h-full object-cover pointer-events-none"
    />
    <!-- Left fade -->
    <div class="absolute inset-y-0 left-0 w-[18%] pointer-events-none" style="background: linear-gradient(to right, #060606 0%, transparent 100%);"></div>
    <!-- Right fade -->
    <div class="absolute inset-y-0 right-0 w-[18%] pointer-events-none" style="background: linear-gradient(to left, #060606 0%, transparent 100%);"></div>
    <!-- Bottom fade -->
    <div class="absolute inset-x-0 bottom-0 h-[25%] pointer-events-none" style="background: linear-gradient(to top, #060606 0%, transparent 100%);"></div>
  </div>
  <div class="relative z-[1] max-w-[1200px] mx-auto">
    <header class="text-center mb-12 reveal">
      <h2
        class="font-heading font-black text-[clamp(1.75rem,4vw,2.75rem)] tracking-[0.08em] uppercase text-white mb-3"
      >
        Líneas de producto
      </h2>
    </header>

    <div class="grid grid-cols-1 min-[480px]:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        products.map((p) => (
          <article class="rounded-2xl overflow-hidden flex flex-col text-center reveal border border-white/80" style="background: linear-gradient(to top, #1b1b1b, #838383);">
            <!-- Card header -->
            <div class="px-5 pt-5 pb-3">
              <h3 class="font-heading font-black text-xl tracking-[0.02em] uppercase text-white leading-[1.1] mb-1">
                {p.name}
              </h3>
              <p class="font-body text-[0.72rem] leading-[1.4] text-white/90">
                {p.subtitle}
              </p>
            </div>

            <!-- Product image -->
            <div class="flex-1 flex items-center justify-center px-4 py-2">
              <img
                src={p.image}
                alt={p.alt}
                width="300"
                height="220"
                loading="lazy"
                class="w-full max-h-[180px] object-contain"
              />
            </div>

            <!-- Card footer -->
            <div class="px-5 pb-5 pt-3 flex flex-col gap-3">
              <p class="font-body text-[0.73rem] leading-[1.65] text-white">
                {p.desc}
              </p>
              {/* <a
                href="#contacto"
                class="btn-fill font-heading font-bold text-[0.7rem] rounded-sm tracking-[0.1em] uppercase text-white no-underline border border-white/25 py-2.5 text-center block relative overflow-hidden"
              >
                <span class="btn-fill__bg absolute inset-0" aria-hidden="true"></span>
                <span class="relative z-10">Ver equipos</span>
              </a> */}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .btn-fill__bg {
    background: rgba(255, 255, 255, 0.12);
    transform: translateX(-105%);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.btn-fill').forEach((btn) => {
    const bg = btn.querySelector<HTMLElement>('.btn-fill__bg');
    if (!bg) return;

    btn.addEventListener('mouseenter', () => {
      bg.style.transition = 'transform 0.35s ease';
      bg.style.transform = 'translateX(0)';
    });

    btn.addEventListener('mouseleave', () => {
      bg.style.transition = 'transform 0.35s ease';
      bg.style.transform = 'translateX(105%)';

      bg.addEventListener('transitionend', () => {
        bg.style.transition = 'none';
        bg.style.transform = 'translateX(-105%)';
      }, { once: true });
    });
  });
</script>
