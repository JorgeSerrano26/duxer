---
const products = [
  {
    name: "Lavado Industrial",
    desc: "Lavadoras de barrera sanitaria de alta capacidad, diseñadas para trabajo continuo con máxima eficiencia.",
    specs: "De 18 kg hasta 120 kg",
    image: "/lavado_industrial.png",
    alt: "Lavadora industrial de barrera sanitaria DUXER, acero inoxidable",
  },
  {
    name: "Secado Inteligente",
    desc: "Secadoras industriales de alta eficiencia energética con control digital de temperatura y humedad.",
    specs: "Ciclos de secado optimizados",
    image: "/secado_inteligente.png",
    alt: "Secadora industrial inteligente DUXER de alta eficiencia",
  },
  {
    name: "Acabado Profesional",
    desc: "Equipos de acabado para ropa y lencería con tecnología de última generación y resultados impecables.",
    specs: "Pliegue y clasificación automática",
    image: "/acabado_profesional.png",
    alt: "Equipo de acabado profesional DUXER para lavandería industrial",
  },
  {
    name: "Planchado",
    desc: "Calandrias y planchas industriales para sábanas, manteles y uniformes con acabado perfecto.",
    specs: "Hasta 600 m² / hora",
    image: "/planchado.png",
    alt: "Calandria industrial DUXER para planchado profesional de lencería",
  },
];
---

<section
  id="productos"
  class="py-22 px-6 relative overflow-hidden"
  aria-label="Líneas de producto"
>
  <div class="absolute w-full h-full left-0 top-0">
    <img
      src="/duxer-bg-01.png"
      alt="Fondo decorativo de textura industrial para sección de productos DUXER"
      width="1400"
      height="550"
      loading="lazy"
      class="inset-0 w-full h-full object-cover pointer-events-none"
    />
    <!-- Left fade -->
    <div class="absolute inset-y-0 left-0 w-[18%] pointer-events-none" style="background: linear-gradient(to right, #060606 0%, transparent 100%);"></div>
    <!-- Right fade -->
    <div class="absolute inset-y-0 right-0 w-[18%] pointer-events-none" style="background: linear-gradient(to left, #060606 0%, transparent 100%);"></div>
    <!-- Bottom fade -->
    <div class="absolute inset-x-0 bottom-0 h-[25%] pointer-events-none" style="background: linear-gradient(to top, #060606 0%, transparent 100%);"></div>
  </div>
  <div class="relative z-[1] max-w-[1200px] mx-auto">
    <header class="text-center mb-12 reveal">
      <h2
        class="font-heading font-black text-[clamp(1.75rem,4vw,2.75rem)] tracking-[0.08em] uppercase text-white mb-3"
      >
        Líneas de producto
      </h2>
      <p
        class="font-body text-[0.85rem] text-white/[0.38] max-w-[380px] mx-auto leading-[1.6]"
      >
        Equipos de alta calidad para cada etapa del proceso de lavandería
        industrial.
      </p>
    </header>

    <div class="grid grid-cols-1 min-[480px]:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        products.map((p) => (
          <article class="bg-[#131313] border border-white/[0.07] overflow-hidden flex flex-col transition-[border-color,transform] duration-300 hover:border-white/20 hover:-translate-y-[4px] group reveal">
            <div class="relative overflow-hidden bg-[#1a1a1a]">
              <img
                src={p.image}
                alt={p.alt}
                width="300"
                height="220"
                loading="lazy"
                class="w-full h-[170px] object-contain block p-4 transition-transform duration-500 group-hover:scale-[1.06]"
              />
              <span class="absolute top-[0.6rem] left-[0.6rem] font-heading font-bold text-[0.52rem] tracking-[0.2em] uppercase text-gold/80 bg-ink/[0.88] border border-gold/20 px-[0.4rem] py-[0.18rem]">
                DUXER
              </span>
            </div>
            <div class="px-[1.1rem] pt-4 pb-5 flex flex-col flex-1">
              <h3 class="font-heading font-extrabold text-[0.95rem] tracking-[0.06em] uppercase text-white mb-[0.45rem]">
                {p.name}
              </h3>
              <p class="font-body text-[0.73rem] leading-[1.6] text-white/40 mb-2 flex-1">
                {p.desc}
              </p>
              <p class="font-body text-[0.67rem] text-gold/65 tracking-[0.03em] mb-3.5">
                {p.specs}
              </p>
              <a
                href="#contacto"
                class="font-heading font-bold text-[0.68rem] tracking-[0.12em] uppercase text-white/55 no-underline border border-white/[0.1] p-[0.45rem] text-center transition-[background,color,border-color] duration-200 block hover:bg-white/[0.07] hover:text-white hover:border-white/[0.28]"
              >
                Ver detalles
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
